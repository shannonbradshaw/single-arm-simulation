<?xml version="1.0"?>
<!--
  Ufactory xArm 6 with xArm Gripper — Standalone SDF for Gazebo Harmonic

  Source: xArm-Developer/xarm_ros2 (jazzy branch)
  Inertial params: xarm6_type6_HT_BR2.yaml
  Kinematics: xarm6_default_kinematics.yaml
  Joint limits: xarm6.urdf.xacro
  Gripper: xarm_gripper.urdf.xacro

  License: BSD-3-Clause (original xarm_ros2 license)
-->
<sdf version="1.9">
  <model name="xarm6">
    <self_collide>false</self_collide>

    <!-- ============================================================ -->
    <!--  PLUGINS                                                      -->
    <!-- ============================================================ -->

    <!-- Publish joint states on /xarm6/joint_states -->
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>xarm6/joint_states</topic>
      <joint_name>joint1</joint_name>
      <joint_name>joint2</joint_name>
      <joint_name>joint3</joint_name>
      <joint_name>joint4</joint_name>
      <joint_name>joint5</joint_name>
      <joint_name>joint6</joint_name>
      <joint_name>drive_joint</joint_name>
    </plugin>

    <!-- Joint position controllers — one per actuated joint -->
    <!-- PID gains are initial estimates; tune for your use case -->

    <!-- Joint 1: base rotation (~1 kg·m² effective inertia) -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint1</joint_name>
      <topic>xarm6/joint1/cmd_pos</topic>
      <p_gain>300</p_gain>
      <i_gain>5</i_gain>
      <d_gain>100</d_gain>
      <cmd_max>100</cmd_max>
      <cmd_min>-100</cmd_min>
      <initial_position>0</initial_position>
    </plugin>

    <!-- Joint 2: shoulder (heaviest gravity load) -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint2</joint_name>
      <topic>xarm6/joint2/cmd_pos</topic>
      <p_gain>600</p_gain>
      <i_gain>10</i_gain>
      <d_gain>200</d_gain>
      <cmd_max>150</cmd_max>
      <cmd_min>-150</cmd_min>
      <initial_position>-0.7854</initial_position>
    </plugin>

    <!-- Joint 3: elbow -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint3</joint_name>
      <topic>xarm6/joint3/cmd_pos</topic>
      <p_gain>300</p_gain>
      <i_gain>5</i_gain>
      <d_gain>100</d_gain>
      <cmd_max>80</cmd_max>
      <cmd_min>-80</cmd_min>
      <initial_position>-0.5236</initial_position>
    </plugin>

    <!-- Joint 4: wrist rotation -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint4</joint_name>
      <topic>xarm6/joint4/cmd_pos</topic>
      <p_gain>100</p_gain>
      <i_gain>2</i_gain>
      <d_gain>50</d_gain>
      <cmd_max>30</cmd_max>
      <cmd_min>-30</cmd_min>
      <initial_position>0</initial_position>
    </plugin>

    <!-- Joint 5: wrist bend -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint5</joint_name>
      <topic>xarm6/joint5/cmd_pos</topic>
      <p_gain>100</p_gain>
      <i_gain>2</i_gain>
      <d_gain>50</d_gain>
      <cmd_max>30</cmd_max>
      <cmd_min>-30</cmd_min>
      <initial_position>1.0472</initial_position>
    </plugin>

    <!-- Joint 6: tool rotation (very lightweight — 0.17 kg link + gripper) -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint6</joint_name>
      <topic>xarm6/joint6/cmd_pos</topic>
      <p_gain>20</p_gain>
      <i_gain>1</i_gain>
      <d_gain>15</d_gain>
      <cmd_max>10</cmd_max>
      <cmd_min>-10</cmd_min>
      <initial_position>0</initial_position>
    </plugin>

    <!-- Gripper drive joint -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>drive_joint</joint_name>
      <topic>xarm6/gripper/cmd_pos</topic>
      <p_gain>50</p_gain>
      <i_gain>1</i_gain>
      <d_gain>20</d_gain>
      <cmd_max>10</cmd_max>
      <cmd_min>-10</cmd_min>
      <initial_position>0</initial_position>
    </plugin>

    <!-- ============================================================ -->
    <!--  ARM BASE                                                     -->
    <!-- ============================================================ -->

    <link name="link_base">
      <pose>0 0 0 0 0 0</pose>

      <inertial>
        <pose>0.0 0.0 0.09103 0 0 0</pose>
        <mass>2.7</mass>
        <inertia>
          <ixx>0.00494875</ixx>
          <ixy>-3.5e-06</ixy>
          <ixz>1.25e-05</ixz>
          <iyy>0.00494174</iyy>
          <iyz>1.67e-06</iyz>
          <izz>0.002219</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link_base.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link_base.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- Fix base to world (removed when mounted on a table/stand) -->
    <joint name="world_joint" type="fixed">
      <parent>world</parent>
      <child>link_base</child>
    </joint>

    <!-- ============================================================ -->
    <!--  JOINT 1 — Base rotation                                      -->
    <!--  Origin from link_base: xyz="0 0 0.267"                       -->
    <!-- ============================================================ -->

    <joint name="joint1" type="revolute">
      <pose relative_to="link_base">0 0 0.267 0 0 0</pose>
      <parent>link_base</parent>
      <child>link1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-6.283185307</lower>
          <upper>6.283185307</upper>
          <effort>200.0</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link1">
      <pose relative_to="joint1">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0.00022 0.02951 -0.0124 0 0 0</pose>
        <mass>2.3814</mass>
        <inertia>
          <ixx>0.0058562</ixx>
          <ixy>-1.79e-05</ixy>
          <ixz>3.55e-06</ixz>
          <iyy>0.0050316</iyy>
          <iyz>-0.000888336</iyz>
          <izz>0.003536652</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link1.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link1.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!--  JOINT 2 — Shoulder                                           -->
    <!--  Origin from link1: xyz="0 0 0" rpy="-1.5708 0 0"            -->
    <!-- ============================================================ -->

    <joint name="joint2" type="revolute">
      <pose relative_to="link1">0 0 0 -1.5708 0 0</pose>
      <parent>link1</parent>
      <child>link2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <initial_position>-0.7854</initial_position>
        <limit>
          <lower>-2.059</lower>
          <upper>2.0944</upper>
          <effort>200.0</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>30.0</damping>
          <friction>3.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link2">
      <pose relative_to="joint2">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0.03881 -0.22783 0.03496 0 0 0</pose>
        <mass>2.2675</mass>
        <inertia>
          <ixx>0.028315776</ixx>
          <ixy>0.005</ixy>
          <ixz>0.00066546</ixz>
          <iyy>0.0058</iyy>
          <iyz>-0.0045741</iyz>
          <izz>0.0273447</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link2.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link2.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!--  JOINT 3 — Elbow                                              -->
    <!--  Origin from link2: xyz="0.0535 -0.2845 0"                    -->
    <!-- ============================================================ -->

    <joint name="joint3" type="revolute">
      <pose relative_to="link2">0.0535 -0.2845 0 0 0 0</pose>
      <parent>link2</parent>
      <child>link3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <initial_position>-0.5236</initial_position>
        <limit>
          <lower>-3.927</lower>
          <upper>0.19198</upper>
          <effort>100.0</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link3">
      <pose relative_to="joint3">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0.07041 0.11631 0.0107 0 0 0</pose>
        <mass>1.875</mass>
        <inertia>
          <ixx>0.0063483</ixx>
          <ixy>-0.0015397</ixy>
          <ixz>0.00096858</ixz>
          <iyy>0.00379758</iyy>
          <iyz>0.00186567</iyz>
          <izz>0.00595768</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link3.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link3.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!--  JOINT 4 — Wrist rotation                                     -->
    <!--  Origin from link3: xyz="0.0775 0.3425 0" rpy="-1.5708 0 0"  -->
    <!-- ============================================================ -->

    <joint name="joint4" type="revolute">
      <pose relative_to="link3">0.0775 0.3425 0 -1.5708 0 0</pose>
      <parent>link3</parent>
      <child>link4</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-6.283185307</lower>
          <upper>6.283185307</upper>
          <effort>200.0</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>15.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link4">
      <pose relative_to="joint4">0 0 0 0 0 0</pose>

      <inertial>
        <pose>-0.00018 0.01798 -0.02291 0 0 0</pose>
        <mass>1.3192</mass>
        <inertia>
          <ixx>0.004896</ixx>
          <ixy>-6.925e-06</ixy>
          <ixz>-1.418e-05</ixz>
          <iyy>0.00445694</iyy>
          <iyz>-0.00023186</iyz>
          <izz>0.00134332</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link4.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link4.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!--  JOINT 5 — Wrist bend                                         -->
    <!--  Origin from link4: xyz="0 0 0" rpy="1.5708 0 0"             -->
    <!-- ============================================================ -->

    <joint name="joint5" type="revolute">
      <pose relative_to="link4">0 0 0 1.5708 0 0</pose>
      <parent>link4</parent>
      <child>link5</child>
      <axis>
        <xyz>0 0 1</xyz>
        <initial_position>1.0472</initial_position>
        <limit>
          <lower>-1.69297</lower>
          <upper>3.141592653</upper>
          <effort>200.0</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>15.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link5">
      <pose relative_to="joint5">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0.0651 0.03096 0.00315 0 0 0</pose>
        <mass>1.33854</mass>
        <inertia>
          <ixx>0.00146378</ixx>
          <ixy>-0.000450624</ixy>
          <ixz>0.000284306</ixz>
          <iyy>0.00184192</iyy>
          <iyz>0.000130866</iyz>
          <izz>0.002333524</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link5.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link5.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!--  JOINT 6 — Tool rotation                                      -->
    <!--  Origin from link5: xyz="0.076 0.097 0" rpy="-1.5708 0 0"    -->
    <!-- ============================================================ -->

    <joint name="joint6" type="revolute">
      <pose relative_to="link5">0.076 0.097 0 -1.5708 0 0</pose>
      <parent>link5</parent>
      <child>link6</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-6.283185307</lower>
          <upper>6.283185307</upper>
          <effort>200.0</effort>
          <velocity>3.14</velocity>
        </limit>
        <dynamics>
          <damping>15.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="link6">
      <pose relative_to="joint6">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0 -0.00677 -0.01098 0 0 0</pose>
        <mass>0.17</mass>
        <inertia>
          <ixx>9.3e-05</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>5.87e-05</iyy>
          <iyz>-3.6e-06</iyz>
          <izz>0.000132</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link6.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.7 0.7 0.72 1</ambient>
          <diffuse>0.75 0.75 0.77 1</diffuse>
          <specular>0.9 0.9 0.9 1</specular>
        </material>
      </visual>

      <!-- D435 camera stand visual — mesh origin is link_eef frame (= link6) -->
      <visual name="d435_visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/d435/d435_with_cam_stand.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
          <specular>0.4 0.4 0.4 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/visual/link6.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- ============================================================ -->
    <!--  GRIPPER — xArm Gripper                                       -->
    <!--  Attached to link6 via fixed joint (at link_eef frame)        -->
    <!--  TCP (tool center point) is 0.172m from gripper base          -->
    <!-- ============================================================ -->

    <!-- Fixed joint: link6 -> gripper base -->
    <joint name="gripper_fix" type="fixed">
      <pose relative_to="link6">0 0 0 0 0 0</pose>
      <parent>link6</parent>
      <child>gripper_base_link</child>
    </joint>

    <link name="gripper_base_link">
      <pose relative_to="gripper_fix">0 0 0 0 0 0</pose>

      <inertial>
        <pose>-0.00065489 -0.0018497 0.048028 0 0 0</pose>
        <mass>0.54156</mass>
        <inertia>
          <ixx>0.00047106</ixx>
          <ixy>3.9292e-07</ixy>
          <ixz>2.6537e-06</ixz>
          <iyy>0.00033072</iyy>
          <iyz>-1.0975e-05</iyz>
          <izz>0.00025642</izz>
        </inertia>
      </inertial>

      <visual name="visual">
        <geometry>
          <mesh><uri>model://xarm6/meshes/gripper/base_link.stl</uri></mesh>
        </geometry>
        <material>
          <ambient>0.9 0.9 0.92 1</ambient>
          <diffuse>0.95 0.95 0.97 1</diffuse>
          <specular>0.8 0.8 0.8 1</specular>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <mesh><uri>model://xarm6/meshes/gripper/base_link.stl</uri></mesh>
        </geometry>
        <surface><contact><collide_bitmask>0x01</collide_bitmask></contact></surface>
      </collision>
    </link>

    <!-- TCP frame: 0.172m from gripper base along z -->
    <frame name="tcp" attached_to="gripper_base_link">
      <pose>0 0 0.172 0 0 0</pose>
    </frame>

    <!-- ============================================================ -->
    <!--  D435 WRIST CAMERA — Intel RealSense D435 on UFactory mount  -->
    <!--  Visual mesh on link6 (mesh origin = link_eef frame).        -->
    <!--  Sensor on d435_link at camera_link transform.               -->
    <!--  Transforms from xarm_ros2 realsense_d435i.urdf.xacro        -->
    <!-- ============================================================ -->

    <!-- Fixed joint: link6 -> d435_link (camera_link frame for sensor) -->
    <joint name="d435_mount" type="fixed">
      <pose relative_to="link6">0.06746 -0.0175 0.0237 3.14159 -1.5708 0</pose>
      <parent>link6</parent>
      <child>d435_link</child>
    </joint>

    <link name="d435_link">
      <pose relative_to="d435_mount">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.122</mass>
        <inertia>
          <ixx>1.1e-04</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>3.6e-05</iyy>
          <iyz>0</iyz>
          <izz>1.0e-04</izz>
        </inertia>
      </inertial>

      <!-- RGBD camera sensor matching Intel RealSense D435 specs -->
      <sensor name="d435_rgbd" type="rgbd_camera">
        <topic>d435</topic>
        <update_rate>15</update_rate>
        <always_on>true</always_on>
        <camera>
          <horizontal_fov>1.5184</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.105</near>
            <far>10.0</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.105</near>
              <far>10.0</far>
            </clip>
          </depth_camera>
          <noise>
            <type>gaussian</type>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </link>

    <!-- ===== Left finger assembly ===== -->

    <!-- Drive joint (primary actuated gripper joint) -->
    <joint name="drive_joint" type="revolute">
      <pose relative_to="gripper_base_link">0 0.035 0.059098 0 0 0</pose>
      <parent>gripper_base_link</parent>
      <child>left_outer_knuckle</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>0</lower>
          <upper>0.85</upper>
          <effort>50</effort>
          <velocity>2</velocity>
        </limit>
        <dynamics>
          <damping>10.0</damping>
          <friction>2.0</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="left_outer_knuckle">
      <pose relative_to="drive_joint">0 0 0 0 0 0</pose>

      <inertial>
        <pose>0 0.021559 0.015181 0 0 0</pose>
        <mass>0.033618</mass>
        <inertia>
          <ixx>1.9111e-05</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>6.6256e-06</iyy>
          <iyz>-7.3008e-06</iyz>

<?xml version="1.0"?>
<model>
  <name>xarm6</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Ufactory xArm 6 robotic arm with xArm gripper.
    Physical parameters (inertials, kinematics, joint limits) extracted from
    xArm-Developer/xarm_ros2 (jazzy branch), xarm_description package.
    Inertial variant: xarm6_type6_HT_BR2 (default).
    Visual meshes: xarm6/visual (STL).
    Collision meshes: xarm6_1305/collision (OBJ, simplified geometry).
  </description>
</model>
